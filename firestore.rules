rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'buivanbac@gmail.com'; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return (!('uid' in data) || data.uid == userId)
          && data.email is string && data.email.size() <= 200
          && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
          && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
          && (!('targetLevel' in data) || (data.targetLevel is string))
          && (!('currentLevel' in data) || (data.currentLevel is string))
          && (!('currentStreak' in data) || (data.currentStreak is number && data.currentStreak >= 0))
          && (!('lastActiveDate' in data) || (data.lastActiveDate is string))
          && (!('lastLessonId' in data) || (data.lastLessonId is string))
          && (!('totalWordsLearned' in data) || (data.totalWordsLearned is number && data.totalWordsLearned >= 0))
          && (!('role' in data) || (data.role in ['student', 'teacher', 'admin']))
          && (!('name' in data) || (data.name is string && data.name.size() <= 100))
          && (!('lastLoginAt' in data) || true)
          && (!('createdAt' in data) || true);
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());

      // --- Daily Plans ---
      match /dailyPlans/{date} {
        function isValidPlan(data) {
          return data.date is string 
            && data.tasks is list && data.tasks.size() <= 20
            && data.totalTasks is number && data.totalTasks >= 0
            && data.completedTasks is number && data.completedTasks >= 0
            && data.progressPercent is number && data.progressPercent >= 0 && data.progressPercent <= 100
            && data.totalPoints is number && data.totalPoints >= 0
            && (!('studyMinutes' in data) || (data.studyMinutes is number && data.studyMinutes >= 0))
            && (!('level' in data) || data.level is string)
            && (!('createdAt' in data) || true)
            && (!('updatedAt' in data) || true);
        }

        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
      }

      // --- Weak Words ---
      match /weakWords/{wordId} {
        function isValidWeakWord(data) {
          return data.wordId is string && data.wordId.size() <= 100
            && data.chinese is string && data.chinese.size() <= 100
            && data.pinyin is string && data.pinyin.size() <= 100
            && data.meaning is string && data.meaning.size() <= 500
            && data.mistakeCount is number && data.mistakeCount >= 0
            && data.correctReviewCount is number && data.correctReviewCount >= 0
            && (data.strengthLevel in ['weak', 'medium', 'improving', 'mastered']);
        }

        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
      }

      // --- Mock Test Results ---
      match /mockTestResults/{resultId} {
        function isValidResult(data) {
          return data.id is string
            && data.testId is string
            && data.score is number && data.score >= 0
            && data.totalQuestions is number && data.totalQuestions >= 0;
        }

        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    // --- Global Content Operations (Read for all, Write for Admin) ---
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /vocabulary/{vocabId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /dialogues/{dialogueId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /mockTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
